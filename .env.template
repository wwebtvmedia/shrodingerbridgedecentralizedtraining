# Cloudflare Configuration
# Copy this file to .env and fill in your values
# DO NOT COMMIT .env TO GIT - it contains sensitive information

# Your domain URL (e.g., https://training.yourdomain.com)
URL=https://training.yourdomain.com

# Cloudflare Tunnel Configuration
CLOUDFLARE_TUNNEL_NAME=training-consolidation-tunnel
CLOUDFLARE_TUNNEL_SUBDOMAIN=training
CLOUDFLARE_TUNNEL_LOCAL_PORT=8080

# Server Configuration
SERVER_PORT=8080
SERVER_HOST=0.0.0.0
NODE_ENV=production

# Application URLs (derived from URL)
PUBLIC_URL=${URL}
API_URL=${URL}/api
WS_URL=wss://${URL#https://}  # Convert https:// to wss://

# Cloudflare Access (optional)
CLOUDFLARE_ACCESS_TEAM_NAME=your-team-name
CLOUDFLARE_ACCESS_AUD_TAG=your-aud-tag

# Monitoring
HEALTH_CHECK_ENDPOINT=/api/health
LOG_LEVEL=info

# Security
# REQUIRED. The consolidation server authenticates every protected HTTP/WS
# request against this token. Generate a strong random value, e.g.:
#   openssl rand -hex 32
# If unset, the server boots with a random ephemeral token (printed to the log)
# so it never silently runs with a shared, public credential.
# The browser client must present the SAME value via window.SWARM_AUTH_TOKEN.
SECRET_TOKEN=

# Comma-separated list of browser origins allowed by CORS. Requests from other
# origins are rejected. Defaults to localhost when unset.
ALLOWED_ORIGINS=https://training.yourdomain.com

# Max concurrent WebSocket connections per client IP (connection-flood guard).
MAX_CONN_PER_IP=20

ENABLE_RATE_LIMITING=true
MAX_REQUESTS_PER_MINUTE=100

# Backup
BACKUP_DIR=/home/pi/backups
BACKUP_RETENTION_DAYS=7