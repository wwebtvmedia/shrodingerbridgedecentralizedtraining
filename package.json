{
  "name": "swarm-schrodinger-bridge",
  "version": "0.2.0",
  "description": "Decentralized swarm training for Schrödinger Bridge models with centralized consolidation server",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "node test.js",
    "format": "prettier --write .",
    "server": "node server/index.js",
    "server:dev": "nodemon server/index.js",
    "start": "node server/index.js",
    "dev:full": "concurrently \"npm run server\" \"npm run dev\""
  },
  "dependencies": {
    "chart.js": "^4.4.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "@tensorflow/tfjs": "^4.17.0",
    "@tensorflow/tfjs-node": "^4.17.0",
    "@tensorflow/tfjs-backend-wasm": "^4.17.0",
    "uuid": "^13.0.0",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "nodemon": "^3.0.1",
    "prettier": "^3.0.0",
    "vite": "^8.0.3"
  },
  "keywords": [
    "webtorch",
    "schrodinger-bridge",
    "swarm-learning",
    "p2p",
    "generative-models",
    "model-consolidation",
